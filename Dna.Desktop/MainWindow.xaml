<Window x:Class="Dna.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dna.Desktop"
        mc:Ignorable="d"
        Title="DORA - Legacy Risk Analyzer" Height="450" Width="800">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Analizador de Riesgos Legacy" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <Label Content="Ruta de la Solución (.sln):"/>
            <DockPanel Margin="0,5,0,20">
                <Button x:Name="BtnBrowse" Content="Buscar..." Width="80" DockPanel.Dock="Right" Click="BtnBrowse_Click"/>
                <TextBox x:Name="TxtSolutionPath" IsReadOnly="True" Margin="0,0,10,0"/>
            </DockPanel>

            <Button x:Name="BtnAnalyze" Content="Iniciar Análisis" Height="40" Background="#27ae60" Foreground="White" Click="BtnAnalyze_Click"/>

            <ProgressBar x:Name="ProgressAnalyze" Height="10" Margin="0,20,0,5" IsIndeterminate="False"/>
            <TextBlock x:Name="TxtStatus" Text="Listo" HorizontalAlignment="Center" Foreground="#7f8c8d"/>
        </StackPanel>
    </Grid>
</Window>
